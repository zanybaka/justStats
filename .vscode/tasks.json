{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project", "${workspaceFolder}/justStats.xcodeproj",
        "-scheme", "justStats",
        "-destination", "platform=macOS",
        "build",
        "CODE_SIGNING_ALLOWED=NO"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project", "${workspaceFolder}/justStats.xcodeproj",
        "-scheme", "justStats",
        "-destination", "platform=macOS",
        "build", "test",
        "CODE_SIGNING_ALLOWED=NO"
      ],
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project", "${workspaceFolder}/justStats.xcodeproj",
        "-scheme", "justStats",
        "-destination", "platform=macOS",
        "clean"
      ],
      "problemMatcher": []
    },
    {
      "label": "Run",
      "type": "shell",
      "command": "xcodebuild -project \"${workspaceFolder}/justStats.xcodeproj\" -scheme justStats -destination 'platform=macOS' build CODE_SIGNING_ALLOWED=NO && open \"$(xcodebuild -project \"${workspaceFolder}/justStats.xcodeproj\" -scheme justStats -destination 'platform=macOS' -showBuildSettings CODE_SIGNING_ALLOWED=NO | awk -F' = ' '/ BUILT_PRODUCTS_DIR = /{print $2; exit}')/justStats.app\"",
      "problemMatcher": [],
      "dependsOn": []
    }
  ]
}
